{
  "languages": {
    "TypeScript": {
      "language_servers": ["oxc", "!biome", "..."],
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "TSX": {
      "language_servers": ["oxc", "!biome", "..."],
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "JavaScript": {
      "language_servers": ["oxc", "!biome", "..."],
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
  },
  "language_servers": ["!biome", "npm-package-json-checker", "package-swift-lsp"],
}
